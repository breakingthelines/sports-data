{
  "name": "@breakingthelines/data-adapters",
  "version": "0.0.1",
  "description": "Transform external sports data formats into BTL's normalised schema",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/breakingthelines/data-adapters.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./statsbomb-open": {
      "types": "./dist/statsbomb-open/index.d.ts",
      "import": "./dist/statsbomb-open/index.js"
    },
    "./template": {
      "types": "./dist/template/index.d.ts",
      "import": "./dist/template/index.js"
    }
  },
  "publishConfig": {
    "access": "restricted",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "bunchee",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest"
  },
  "dependencies": {
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@breakingthelines/protos": "^0.0.18",
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "4.0.16",
    "bunchee": "^6.9.3",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "typescript": "~5.9.3",
    "vitest": "4.0.16"
  },
  "peerDependencies": {
    "@breakingthelines/protos": ">=0.0.18"
  },
  "peerDependenciesMeta": {
    "@breakingthelines/protos": {
      "optional": true
    }
  }
}
