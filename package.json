{
  "name": "@breakingthelines/sports-data",
  "version": "0.0.2",
  "description": "Transform external sports data formats into BTL's normalised proto schema",
  "license": "AGPL-3.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/breakingthelines/sports-data.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "sideEffects": false,
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./adapters/statsbomb-open": {
      "types": "./dist/adapters/statsbomb-open/index.d.ts",
      "import": "./dist/adapters/statsbomb-open/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "scripts": {
    "build": "bunchee",
    "check": "tsc --noEmit",
    "lint": "oxlint",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "vitest"
  },
  "dependencies": {
    "@bufbuild/protobuf": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "@vitest/coverage-v8": "4.0.16",
    "bunchee": "^6.9.3",
    "oxfmt": "^0.21.0",
    "oxlint": "^1.36.0",
    "typescript": "~5.9.3",
    "vitest": "4.0.16"
  }
}
